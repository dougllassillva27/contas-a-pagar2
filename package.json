{
  "name": "gestao-financeira-cloud",
  "version": "1.0.0",
  "description": "Sistema de controle financeiro pessoal com PostgreSQL",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --verbose",
    "test:unit": "jest __tests__/helpers __tests__/middlewares --verbose",
    "test:integration": "jest __tests__/integration --verbose",
    "telegram:setup": "node src/modules/botTelegram/setupWebhook.js"
  },
  "keywords": [
    "financas",
    "nodejs",
    "postgresql"
  ],
  "author": "Douglas Silva",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.4",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.19.0",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testTimeout": 10000
  }
}
