    %>

    <main class="page">
      <div class="lajeado-layout">
        <div class="lajeado-content">
      <section class="hero">
        <div class="hero-top">
          <div class="hero-copy">
            <div class="eyebrow">Planejamento financeiro • Lajeado</div>
            <h1>Organização de contas</h1>
            <p>
              Página pública organizada no mesmo clima visual do sistema principal,
              com leitura rápida, destaque dos valores e visão mensal separada por pessoa.
            </p>

            <div class="hero-actions">
              <a class="hero-btn primary" href="#conteudo">Ver planejamento</a>
              <a class="hero-btn" href="/login">Voltar ao sistema</a>
            </div>
          </div>

          <div class="hero-badge">
            <small>Documento</small>
            <strong>Lajeado</strong>
          </div>
        </div>
      </section>

      <section class="summary-grid">
        <article class="summary-card accent-blue">
          <small>Douglas • total disponível</small>
          <strong><%= dados.douglas.resumo.total %></strong>
          <span>Guardado + saque aniversário</span>
        </article>

        <article class="summary-card accent-orange">
          <small>Vitória • total guardado</small>
          <strong><%= dados.vitoria.resumo.total %></strong>
          <span>Base atual para organização mensal</span>
        </article>

        <article class="summary-card accent-green">
          <small>Visão consolidada</small>
          <strong>2 pessoas</strong>
          <span>Planejamento separado por blocos mensais</span>
        </article>
      </section>

      <section class="people-grid" id="conteudo">
        <article class="person-card">
          <header class="person-header">
            <div class="person-title-row">
              <h2 class="person-title"><%= dados.douglas.nome %></h2>
              <span class="person-tag"><%= dados.douglas.tag %></span>
            </div>

            <div class="person-stats">
              <div class="person-stat">
                <small>Guardado</small>
                <strong><%= dados.douglas.resumo.guardado %></strong>
              </div>
              <div class="person-stat">
                <small>Saque aniversário</small>
                <strong><%= dados.douglas.resumo.saque %></strong>
              </div>
              <div class="person-stat">
                <small>Total</small>
                <strong><%= dados.douglas.resumo.total %></strong>
              </div>
            </div>
          </header>

          <div class="person-body">
            <div class="month-list">
              <% dados.douglas.meses.forEach((mes) => { %>
                <section class="month-card">
                  <div class="month-top">
                    <h3 class="month-title"><%= mes.titulo %></h3>
                    <span class="month-chip <%= mes.statusClass %>"><%= mes.statusLabel %></span>
                  </div>

                  <div class="month-metrics">
                    <% mes.metricas.forEach((metrica) => { %>
                      <div class="metric">
                        <span class="metric-label"><%= metrica.label %></span>
                        <strong class="metric-value <%= metrica.classe %>"><%= metrica.valor %></strong>
                      </div>
                    <% }) %>
                  </div>
                </section>
              <% }) %>
            </div>
          </div>
        </article>

        <article class="person-card">
          <header class="person-header">
            <div class="person-title-row">
              <h2 class="person-title"><%= dados.vitoria.nome %></h2>
              <span class="person-tag"><%= dados.vitoria.tag %></span>
            </div>

            <div class="person-stats">
              <div class="person-stat">
                <small>Guardado</small>
                <strong><%= dados.vitoria.resumo.guardado %></strong>
              </div>
              <div class="person-stat">
                <small>Saque aniversário</small>
                <strong><%= dados.vitoria.resumo.saque %></strong>
              </div>
              <div class="person-stat">
                <small>Total</small>
                <strong><%= dados.vitoria.resumo.total %></strong>
              </div>
            </div>
          </header>

          <div class="person-body">
            <div class="month-list">
              <% dados.vitoria.meses.forEach((mes) => { %>
                <section class="month-card">
                  <div class="month-top">
                    <h3 class="month-title"><%= mes.titulo %></h3>
                    <span class="month-chip <%= mes.statusClass %>"><%= mes.statusLabel %></span>
                  </div>

                  <div class="month-metrics">
                    <% mes.metricas.forEach((metrica) => { %>
                      <div class="metric">
                        <span class="metric-label"><%= metrica.label %></span>
                        <strong class="metric-value <%= metrica.classe %>"><%= metrica.valor %></strong>
                      </div>
                    <% }) %>
                  </div>
                </section>
              <% }) %>
            </div>
          </div>
        </article>
      </section>
        </div>

        <aside class="lajeado-sidebar">
          <section class="mural-card sidebar-mural">
            <h2 class="mural-header">Mural de Anotações</h2>
            <p class="mural-desc">Espaço livre para anotações do planejamento. O conteúdo é salvo na nuvem automaticamente.</p>
            <textarea id="muralTextarea" class="mural-textarea" placeholder="Digite suas anotações, lembretes ou metas aqui..."><%= typeof muralLajeado !== 'undefined' ? muralLajeado : '' %></textarea>
            <div id="muralStatus" class="mural-status"></div>
          </section>
        </aside>
      </div>

      <div class="footer-note">
        Página pública estilizada a partir do conteúdo original de <code>Lajeado.md</code>.
      </div>
    </main>

    <button
      class="floating-top"
      type="button"
      aria-label="Voltar ao topo"
      title="Voltar ao topo"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    >
      ↑
    </button>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const textarea = document.getElementById('muralTextarea');
        const status = document.getElementById('muralStatus');

        let timeout;
        textarea.addEventListener('input', () => {
          status.textContent = 'Salvando...';
          status.style.color = 'var(--text-secondary)';
          clearTimeout(timeout);
          timeout = setTimeout(async () => {
            try {
              const res = await fetch('/api/anotacoes', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ conteudo: textarea.value, month: -1, year: -1 })
              });
              if (res.ok) {
                status.textContent = '✓ Salvo na nuvem';
                status.style.color = 'var(--green)';
              } else {
                status.textContent = '❌ Erro ao salvar (Faça login)';
                status.style.color = 'var(--red)';
              }
            } catch(e) {
              status.textContent = '❌ Erro de rede';
              status.style.color = 'var(--red)';
            }
          }, 800);
        });
      });
    </script>
  </body>
</html>