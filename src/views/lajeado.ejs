<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <title>Organização de contas | Lajeado</title>
    <meta
      name="description"
      content="Planejamento financeiro e organização de contas de Douglas e Vitória."
    />
    <meta name="robots" content="noindex, nofollow" />

    <style>
      :root {
        --bg-dark: #121212;
        --bg-card: #1e1e1e;
        --bg-soft: #181818;
        --bg-chip: rgba(255, 255, 255, 0.06);
        --text-primary: #ffffff;
        --text-secondary: #a0a0a0;
        --text-muted: #7b7b7b;
        --blue: #3878e1;
        --blue-hover: #2b62c0;
        --red: #ef5350;
        --green: #66bb6a;
        --orange: #ffa726;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.14);
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        --shadow-soft: 0 6px 18px rgba(0, 0, 0, 0.22);
        --radius: 18px;
        --radius-sm: 12px;
        --container: 1320px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(56, 120, 225, 0.12), transparent 28%),
          radial-gradient(circle at top right, rgba(102, 187, 106, 0.08), transparent 20%),
          linear-gradient(180deg, #141414 0%, #121212 100%);
        color: var(--text-primary);
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        padding: 32px 20px 56px;
      }

      a {
        color: inherit;
      }

      .page {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
      }

      .hero {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(56, 120, 225, 0.12), rgba(56, 120, 225, 0.03)),
          var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
        padding: 28px;
        margin-bottom: 24px;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: auto -60px -60px auto;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(56, 120, 225, 0.2), transparent 65%);
        pointer-events: none;
      }

      .hero-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
      }

      .hero-copy {
        max-width: 760px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(56, 120, 225, 0.12);
        border: 1px solid rgba(56, 120, 225, 0.18);
        color: #9fc1ff;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 14px;
      }

      h1 {
        margin: 0 0 10px;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
      }

      .hero p {
        margin: 0;
        color: var(--text-secondary);
        font-size: 1rem;
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 22px;
      }

      .hero-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 10px 16px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.92rem;
        transition: 0.2s ease;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text-primary);
      }

      .hero-btn:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.08);
        border-color: var(--border-strong);
      }

      .hero-btn.primary {
        background: var(--blue);
        border-color: rgba(56, 120, 225, 0.45);
      }

      .hero-btn.primary:hover {
        background: var(--blue-hover);
      }

      .hero-badge {
        min-width: 180px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 16px;
        box-shadow: var(--shadow-soft);
      }

      .hero-badge small {
        display: block;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        margin-bottom: 6px;
      }

      .hero-badge strong {
        display: block;
        font-size: 1.2rem;
        color: var(--text-primary);
      }

      .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
      }

      .summary-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 20px;
        box-shadow: var(--shadow-soft);
      }

      .summary-card small {
        display: block;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        margin-bottom: 8px;
      }

      .summary-card strong {
        display: block;
        font-size: clamp(1.35rem, 2vw, 1.9rem);
        line-height: 1.1;
        margin-bottom: 6px;
      }

      .summary-card span {
        color: var(--text-secondary);
        font-size: 0.92rem;
      }

      .summary-card.accent-blue {
        background:
          linear-gradient(135deg, rgba(56, 120, 225, 0.14), rgba(56, 120, 225, 0.04)),
          var(--bg-card);
      }

      .summary-card.accent-green {
        background:
          linear-gradient(135deg, rgba(102, 187, 106, 0.12), rgba(102, 187, 106, 0.03)),
          var(--bg-card);
      }

      .summary-card.accent-orange {
        background:
          linear-gradient(135deg, rgba(255, 167, 38, 0.12), rgba(255, 167, 38, 0.03)),
          var(--bg-card);
      }

      .people-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 22px;
      }

      .person-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 24px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .person-header {
        padding: 24px 24px 18px;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
      }

      .person-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 16px;
      }

      .person-title {
        margin: 0;
        font-size: 1.5rem;
        letter-spacing: -0.02em;
      }

      .person-tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 7px 11px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        background: var(--bg-chip);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        white-space: nowrap;
      }

      .person-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }

      .person-stat {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 14px;
      }

      .person-stat small {
        display: block;
        color: var(--text-secondary);
        font-size: 0.78rem;
        margin-bottom: 6px;
      }

      .person-stat strong {
        display: block;
        font-size: 1.06rem;
        line-height: 1.2;
      }

      .person-body {
        padding: 22px 24px 24px;
      }

      .month-list {
        display: grid;
        gap: 14px;
      }

      .month-card {
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 16px;
        transition: 0.2s ease;
      }

      .month-card:hover {
        transform: translateY(-1px);
        border-color: var(--border-strong);
      }

      .month-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
      }

      .month-title {
        margin: 0;
        font-size: 1rem;
      }

      .month-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 28px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border: 1px solid transparent;
        white-space: nowrap;
      }

      .month-chip.warning {
        color: #ffb4b4;
        background: rgba(239, 83, 80, 0.12);
        border-color: rgba(239, 83, 80, 0.18);
      }

      .month-chip.success {
        color: #b8efbb;
        background: rgba(102, 187, 106, 0.12);
        border-color: rgba(102, 187, 106, 0.18);
      }

      .month-chip.info {
        color: #b8d4ff;
        background: rgba(56, 120, 225, 0.12);
        border-color: rgba(56, 120, 225, 0.18);
      }

      .month-metrics {
        display: grid;
        gap: 10px;
      }

      .metric {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding-bottom: 10px;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.08);
      }

      .metric:last-child {
        padding-bottom: 0;
        border-bottom: 0;
      }

      .metric-label {
        color: var(--text-secondary);
        font-size: 0.92rem;
      }

      .metric-value {
        color: var(--text-primary);
        font-weight: 700;
        white-space: nowrap;
        text-align: right;
      }

      .metric-value.red {
        color: var(--red);
      }

      .metric-value.green {
        color: var(--green);
      }

      .metric-value.blue {
        color: var(--blue);
      }

      .footer-note {
        margin-top: 28px;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.82rem;
      }

      .floating-top {
        position: fixed;
        right: 22px;
        bottom: 22px;
        width: 52px;
        height: 52px;
        border: 0;
        border-radius: 50%;
        background: var(--blue);
        color: #fff;
        font-size: 1.2rem;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(56, 120, 225, 0.38);
        transition: 0.2s ease;
      }

      .floating-top:hover {
        background: var(--blue-hover);
        transform: translateY(-2px);
      }

      @media (max-width: 1024px) {
        .summary-grid {
          grid-template-columns: 1fr;
        }

        .people-grid {
          grid-template-columns: 1fr;
        }

        .hero-top {
          flex-direction: column;
        }

        .hero-badge {
          width: 100%;
          min-width: 0;
        }
      }

      @media (max-width: 768px) {
        body {
          padding: 18px 14px 40px;
        }

        .hero {
          padding: 20px;
          border-radius: 22px;
        }

        .person-header,
        .person-body {
          padding-left: 18px;
          padding-right: 18px;
        }

        .person-stats {
          grid-template-columns: 1fr;
        }

        .month-top,
        .metric {
          flex-direction: column;
          align-items: flex-start;
        }

        .metric-value {
          text-align: left;
        }

        .hero-actions {
          flex-direction: column;
        }

        .hero-btn {
          width: 100%;
        }
      }

      /* --- Layout Dividido (Sidebar Mural) --- */
      .lajeado-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
      }
      .lajeado-sidebar {
        position: sticky;
        top: 32px;
        height: calc(100vh - 64px);
        display: flex;
        flex-direction: column;
      }
      @media (max-width: 1024px) {
        .lajeado-layout {
          grid-template-columns: 1fr;
        }
        .lajeado-sidebar {
          position: static;
          height: auto;
        }
      }

      /* --- Estilos do Mural --- */
      .mural-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 24px;
        box-shadow: var(--shadow);
      }
      .sidebar-mural {
        flex: 1;
        display: flex;
        flex-direction: column;
        margin-top: 0;
      }
      .mural-header {
        margin-top: 0;
        font-size: 1.5rem;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
      }
      .mural-desc {
        color: var(--text-secondary);
        font-size: 0.95rem;
        margin-bottom: 20px;
      }
      .mural-textarea {
        width: 100%;
        min-height: 220px;
        background: rgba(0,0,0,0.15);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 16px;
        color: var(--text-primary);
        font-family: inherit;
        font-size: 0.95rem;
        line-height: 1.6;
        resize: vertical;
        outline: none;
        transition: border-color 0.2s;
      }
      .sidebar-mural .mural-textarea {
        flex: 1;
        resize: none;
        min-height: 250px;
      }
      .mural-textarea:focus {
        border-color: var(--blue);
        background: rgba(0,0,0,0.25);
      }
      .mural-status {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        height: 24px;
        margin-top: 8px;
        font-size: 0.85rem;
        color: var(--text-secondary);
        transition: color 0.3s ease;
      }
    </style>
  </head>
  <body>
