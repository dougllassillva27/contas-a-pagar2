<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <title>Organização de contas | Lajeado</title>
    <meta
      name="description"
      content="Planejamento financeiro e organização de contas de Douglas e Vitória."
    />
    <meta name="robots" content="noindex, nofollow" />

    <!-- Injeção das fontes e ícones padrões do sistema principal -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />

    <style>
      :root {
        --bg-dark: #121212;
        --bg-card: #1e1e1e;
        --bg-soft: #181818;
        --bg-chip: rgba(255, 255, 255, 0.06);
        --text-primary: #ffffff;
        --text-secondary: #a0a0a0;
        --text-muted: #7b7b7b;
        --blue: #3878e1;
        --blue-hover: #2b62c0;
        --red: #ef5350;
        --green: #66bb6a;
        --orange: #ffa726;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.14);
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        --shadow-soft: 0 6px 18px rgba(0, 0, 0, 0.22);
        --radius: 18px;
        --radius-sm: 12px;
        --container: 1320px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(56, 120, 225, 0.12), transparent 28%),
          radial-gradient(circle at top right, rgba(102, 187, 106, 0.08), transparent 20%),
          linear-gradient(180deg, #141414 0%, #121212 100%);
        color: var(--text-primary);
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        padding: 32px 20px 56px;
      }

      a {
        color: inherit;
      }

      .page {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
      }

      .hero {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(56, 120, 225, 0.12), rgba(56, 120, 225, 0.03)),
          var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
        padding: 28px;
        margin-bottom: 24px;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: auto -60px -60px auto;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(56, 120, 225, 0.2), transparent 65%);
        pointer-events: none;
      }

      .hero-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
      }

      .hero-copy {
        max-width: 760px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(56, 120, 225, 0.12);
        border: 1px solid rgba(56, 120, 225, 0.18);
        color: #9fc1ff;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 14px;
      }

      h1 {
        margin: 0 0 10px;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
      }

      .hero p {
        margin: 0;
        color: var(--text-secondary);
        font-size: 1rem;
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 22px;
      }

      .hero-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 10px 16px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.92rem;
        transition: 0.2s ease;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text-primary);
      }

      .hero-btn:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.08);
        border-color: var(--border-strong);
      }

      .hero-btn.primary {
        background: var(--blue);
        border-color: rgba(56, 120, 225, 0.45);
      }

      .hero-btn.primary:hover {
        background: var(--blue-hover);
      }

      .hero-badge {
        min-width: 180px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 16px;
        box-shadow: var(--shadow-soft);
      }

      .hero-badge small {
        display: block;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        margin-bottom: 6px;
      }

      .hero-badge strong {
        display: block;
        font-size: 1.2rem;
        color: var(--text-primary);
      }

      .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
      }

      .summary-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 20px;
        box-shadow: var(--shadow-soft);
      }

      .summary-card small {
        display: block;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        margin-bottom: 8px;
      }

      .summary-card strong {
        display: block;
        font-size: clamp(1.35rem, 2vw, 1.9rem);
        line-height: 1.1;
        margin-bottom: 6px;
      }

      .summary-card span {
        color: var(--text-secondary);
        font-size: 0.92rem;
      }

      .summary-card.accent-blue {
        background:
          linear-gradient(135deg, rgba(56, 120, 225, 0.14), rgba(56, 120, 225, 0.04)),
          var(--bg-card);
      }

      .summary-card.accent-green {
        background:
          linear-gradient(135deg, rgba(102, 187, 106, 0.12), rgba(102, 187, 106, 0.03)),
          var(--bg-card);
      }

      .summary-card.accent-orange {
        background:
          linear-gradient(135deg, rgba(255, 167, 38, 0.12), rgba(255, 167, 38, 0.03)),
          var(--bg-card);
      }

      .people-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 22px;
      }

      .person-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 24px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .person-header {
        padding: 24px 24px 18px;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
      }

      .person-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 16px;
      }

      .person-title {
        margin: 0;
        font-size: 1.5rem;
        letter-spacing: -0.02em;
      }

      .person-tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 7px 11px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        background: var(--bg-chip);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        white-space: nowrap;
      }

      .person-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }

      .person-stat {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 14px;
      }

      .person-stat small {
        display: block;
        color: var(--text-secondary);
        font-size: 0.78rem;
        margin-bottom: 6px;
      }

      .person-stat strong {
        display: block;
        font-size: 1.06rem;
        line-height: 1.2;
      }

      .person-body {
        padding: 22px 24px 24px;
      }

      .month-list {
        display: grid;
        gap: 14px;
      }

      .month-card {
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 16px;
        transition: 0.2s ease;
      }

      .month-card:hover {
        transform: translateY(-1px);
        border-color: var(--border-strong);
      }

      .month-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
      }

      .month-title {
        margin: 0;
        font-size: 1rem;
      }

      .month-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 28px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border: 1px solid transparent;
        white-space: nowrap;
      }

      .month-chip.warning {
        color: #ffb4b4;
        background: rgba(239, 83, 80, 0.12);
        border-color: rgba(239, 83, 80, 0.18);
      }

      .month-chip.success {
        color: #b8efbb;
        background: rgba(102, 187, 106, 0.12);
        border-color: rgba(102, 187, 106, 0.18);
      }

      .month-chip.info {
        color: #b8d4ff;
        background: rgba(56, 120, 225, 0.12);
        border-color: rgba(56, 120, 225, 0.18);
      }

      .month-metrics {
        display: grid;
        gap: 10px;
      }

      .metric {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding-bottom: 10px;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.08);
      }

      .metric:last-child {
        padding-bottom: 0;
        border-bottom: 0;
      }

      .metric-label {
        color: var(--text-secondary);
        font-size: 0.92rem;
      }

      .metric-value {
        color: var(--text-primary);
        font-weight: 700;
        white-space: nowrap;
        text-align: right;
      }

      .metric-value.red {
        color: var(--red);
      }

      .metric-value.green {
        color: var(--green);
      }

      .metric-value.blue {
        color: var(--blue);
      }

      .footer-note {
        margin-top: 28px;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.82rem;
      }

      .floating-top {
        position: fixed;
        right: 22px;
        bottom: 22px;
        width: 52px;
        height: 52px;
        border: 0;
        border-radius: 50%;
        background: var(--blue);
        color: #fff;
        font-size: 1.2rem;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(56, 120, 225, 0.38);
        transition: 0.2s ease;
      }

      .floating-top:hover {
        background: var(--blue-hover);
        transform: translateY(-2px);
      }

      @media (max-width: 1024px) {
        .summary-grid {
          grid-template-columns: 1fr;
        }

        .people-grid {
          grid-template-columns: 1fr;
        }

        .hero-top {
          flex-direction: column;
        }

        .hero-badge {
          width: 100%;
          min-width: 0;
        }
      }

      @media (max-width: 768px) {
        body {
          padding: 18px 14px 40px;
        }

        .hero {
          padding: 20px;
          border-radius: 22px;
        }

        .person-header,
        .person-body {
          padding-left: 18px;
          padding-right: 18px;
        }

        .person-stats {
          grid-template-columns: 1fr;
        }

        .month-top,
        .metric {
          flex-direction: column;
          align-items: flex-start;
        }

        .metric-value {
          text-align: left;
        }

        .hero-actions {
          flex-direction: column;
        }

        .hero-btn {
          width: 100%;
        }
      }

      /* --- Layout Dividido (Sidebar Mural) --- */
      .lajeado-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
      }
      .lajeado-sidebar {
        position: sticky;
        top: 32px;
        height: calc(100vh - 64px);
        display: flex;
        flex-direction: column;
      }
      @media (max-width: 1024px) {
        .lajeado-layout {
          grid-template-columns: 1fr;
        }
        .lajeado-sidebar {
          position: static;
          height: auto;
        }
      }

      /* --- Estilos do Mural --- */
      .mural-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 24px;
        box-shadow: var(--shadow);
      }
      .sidebar-mural {
        flex: 1;
        display: flex;
        flex-direction: column;
        margin-top: 0;
      }
      .mural-header {
        margin-top: 0;
        font-size: 1.5rem;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
      }
      .mural-desc {
        color: var(--text-secondary);
        font-size: 0.95rem;
        margin-bottom: 20px;
      }
      .mural-textarea {
        width: 100%;
        min-height: 220px;
        background: rgba(0,0,0,0.15);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 16px;
        color: var(--text-primary);
        font-family: inherit;
        font-size: 0.95rem;
        line-height: 1.6;
        resize: vertical;
        outline: none;
        transition: border-color 0.2s;
      }
      .sidebar-mural .mural-textarea {
        flex: 1;
        resize: none;
        min-height: 250px;
      }
      .mural-textarea:focus {
        border-color: var(--blue);
        background: rgba(0,0,0,0.25);
      }
      .mural-status {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        height: 24px;
        margin-top: 8px;
        font-size: 0.85rem;
        color: var(--text-secondary);
        transition: color 0.3s ease;
      }

      /* --- Elementos do Modo Edição Visual --- */
      .edit-input {
        background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #fff;
        padding: 6px 10px; border-radius: 8px; font-family: inherit; font-size: 0.95rem; outline: none; width: 100%; transition: border-color 0.2s;
      }
      .edit-input:focus { border-color: var(--blue); }
      .tag-input { text-align: center; font-size: 0.75rem; padding: 4px; }
      .btn-del {
        background: rgba(239,83,80,0.1); border: 1px solid rgba(239,83,80,0.3); color: var(--red); border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 4px; transition: 0.2s;
      }
      .btn-del:hover { background: var(--red); color: white; }
      .btn-add { background: rgba(255,255,255,0.05); border: 1px dashed rgba(255,255,255,0.2); color: var(--text-secondary); padding: 8px 12px; border-radius: 8px; cursor: pointer; font-size: 0.85rem; width: 100%; transition: 0.2s; font-weight: 600; }
      .btn-add:hover { background: rgba(255,255,255,0.1); color: #fff; }
      .btn-add.primary { border-color: rgba(56,120,225,0.4); color: var(--blue); background: rgba(56,120,225,0.05); }
      .btn-add.primary:hover { background: var(--blue); color: white; }
    </style>
  </head>
  <body>
    <main class="page">
      <div class="lajeado-layout">
        <div class="lajeado-content">
      <section class="hero">
        <div class="hero-top">
          <div class="hero-copy">
            <div class="eyebrow">
              Planejamento financeiro • Lajeado
              <% if (typeof user !== 'undefined' && user) { %>
                <button onclick="toggleLayoutEditMode()" style="margin-left: 12px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; background: rgba(255,167,38,0.15); color: var(--warning); border: 1px solid rgba(255,167,38,0.3); padding: 4px 10px; border-radius: 999px; font-size: 0.8rem; font-weight: 700; transition: 0.2s;" title="Editar painel visualmente">
                  <span class="material-icons" style="font-size: 14px;">edit</span> Modo Edição
                </button>
              <% } %>
            </div>
            <h1>Organização de contas</h1>
            <p>
              Página pública organizada no mesmo clima visual do sistema principal,
              com leitura rápida, destaque dos valores e visão mensal separada por pessoa.
            </p>

            <div class="hero-actions">
              <a class="hero-btn primary" href="#conteudo">Ver planejamento</a>
              <a class="hero-btn" href="/login">Voltar ao sistema</a>
            </div>
          </div>

          <div class="hero-badge">
            <small>Documento</small>
            <strong>Lajeado</strong>
          </div>
        </div>
      </section>

      <section class="summary-grid">
        <article class="summary-card accent-blue">
          <small>Douglas • total disponível</small>
          <strong><%= dados.douglas.resumo.total %></strong>
          <span>Guardado + saque aniversário</span>
        </article>

        <article class="summary-card accent-orange">
          <small>Vitória • total guardado</small>
          <strong><%= dados.vitoria.resumo.total %></strong>
          <span>Base atual para organização mensal</span>
        </article>

        <article class="summary-card accent-green">
          <small>Visão consolidada</small>
          <strong>2 pessoas</strong>
          <span>Planejamento separado por blocos mensais</span>
        </article>
      </section>

      <section class="people-grid" id="conteudo">
        <article class="person-card">
          <header class="person-header">
            <div class="person-title-row">
              <h2 class="person-title"><%= dados.douglas.nome %></h2>
              <span class="person-tag"><%= dados.douglas.tag %></span>
            </div>

            <div class="person-stats">
              <div class="person-stat">
                <small>Guardado</small>
                <strong><%= dados.douglas.resumo.guardado %></strong>
              </div>
              <div class="person-stat">
                <small>Saque aniversário</small>
                <strong><%= dados.douglas.resumo.saque %></strong>
              </div>
              <div class="person-stat">
                <small>Total</small>
                <strong><%= dados.douglas.resumo.total %></strong>
              </div>
            </div>
          </header>

          <div class="person-body">
            <div class="month-list">
              <% dados.douglas.meses.forEach((mes) => { %>
                <section class="month-card">
                  <div class="month-top">
                    <h3 class="month-title"><%= mes.titulo %></h3>
                    <span class="month-chip <%= mes.statusClass %>"><%= mes.statusLabel %></span>
                  </div>

                  <div class="month-metrics">
                    <% mes.metricas.forEach((metrica) => { %>
                      <div class="metric">
                        <span class="metric-label"><%= metrica.label %></span>
                        <strong class="metric-value <%= metrica.classe %>"><%= metrica.valor %></strong>
                      </div>
                    <% }) %>
                  </div>
                </section>
              <% }) %>
            </div>
          </div>
        </article>

        <article class="person-card">
          <header class="person-header">
            <div class="person-title-row">
              <h2 class="person-title"><%= dados.vitoria.nome %></h2>
              <span class="person-tag"><%= dados.vitoria.tag %></span>
            </div>

            <div class="person-stats">
              <div class="person-stat">
                <small>Guardado</small>
                <strong><%= dados.vitoria.resumo.guardado %></strong>
              </div>
              <div class="person-stat">
                <small>Saque aniversário</small>
                <strong><%= dados.vitoria.resumo.saque %></strong>
              </div>
              <div class="person-stat">
                <small>Total</small>
                <strong><%= dados.vitoria.resumo.total %></strong>
              </div>
            </div>
          </header>

          <div class="person-body">
            <div class="month-list">
              <% dados.vitoria.meses.forEach((mes) => { %>
                <section class="month-card">
                  <div class="month-top">
                    <h3 class="month-title"><%= mes.titulo %></h3>
                    <span class="month-chip <%= mes.statusClass %>"><%= mes.statusLabel %></span>
                  </div>

                  <div class="month-metrics">
                    <% mes.metricas.forEach((metrica) => { %>
                      <div class="metric">
                        <span class="metric-label"><%= metrica.label %></span>
                        <strong class="metric-value <%= metrica.classe %>"><%= metrica.valor %></strong>
                      </div>
                    <% }) %>
                  </div>
                </section>
              <% }) %>
            </div>
          </div>
        </article>
      </section>
        </div>

        <aside class="lajeado-sidebar">
          <section class="mural-card sidebar-mural">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
              <h2 class="mural-header" style="margin-bottom: 0;">Mural de Anotações</h2>
              <button id="btnMuralModo" onclick="alternarModoMural()" style="display: flex; align-items: center; gap: 4px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--text-secondary); padding: 6px 12px; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: 0.2s;">
                <span class="material-icons" style="font-size: 16px;">visibility</span> Preview
              </button>
            </div>
            <p class="mural-desc">Espaço livre para anotações do planejamento. O conteúdo é salvo na nuvem automaticamente.</p>
            
            <!-- Engine de Preview (Escondida enquanto edita) -->
            <div id="muralPreview" class="mural-textarea" style="display: none; overflow-y: auto; white-space: pre-wrap; word-break: break-word;"></div>
            <textarea id="muralTextarea" class="mural-textarea" placeholder="Digite suas anotações, lembretes ou metas aqui..."><%= typeof muralLajeado !== 'undefined' ? muralLajeado : '' %></textarea>
            
            <div id="muralStatus" class="mural-status"></div>
          </section>
        </aside>
      </div>

      <div class="footer-note">
        Página pública de planejamento financeiro integrado.
      </div>
    </main>

    <button
      class="floating-top"
      type="button"
      aria-label="Voltar ao topo"
      title="Voltar ao topo"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    >
      ↑
    </button>

    <!-- Floating Action Bar do Modo Edição -->
    <% if (typeof user !== 'undefined' && user) { %>
      <div id="barSalvarLayout" style="display:none; position:fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: var(--bg-card); border: 2px solid var(--blue); padding: 12px 24px; border-radius: 50px; z-index: 1000; box-shadow: 0 10px 40px rgba(0,0,0,0.8); align-items: center; gap: 20px;">
        <span style="font-weight: 700; color: #fff; display: flex; align-items: center; gap: 8px;"><span class="material-icons" style="color: var(--warning);">edit</span> Modo Edição</span>
        <div style="display:flex; gap:12px;">
          <button onclick="toggleLayoutEditMode()" class="hero-btn" style="min-height: 40px; padding: 0 20px; background: rgba(255,255,255,0.05); border: none;">Cancelar</button>
          <button id="btnSalvarLajeado" onclick="salvarLayoutDados()" class="hero-btn primary" style="min-height: 40px; padding: 0 20px; box-shadow: 0 4px 15px rgba(56, 120, 225, 0.4);">Salvar Alterações</button>
        </div>
      </div>
    <% } %>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const textarea = document.getElementById('muralTextarea');
        const status = document.getElementById('muralStatus');
        const preview = document.getElementById('muralPreview');
        const btnModo = document.getElementById('btnMuralModo');

        let isEditMode = true;

        function renderPreview() {
          let text = textarea.value;
          if (!text.trim()) {
            preview.innerHTML = '<div style="color: var(--text-secondary); font-style: italic; text-align: center; padding: 20px;">Nenhuma anotação...</div>';
            return;
          }

          // Anti-XSS (Segurança)
          let parsed = text.replace(/</g, '&lt;').replace(/>/g, '&gt;');
          
          // Negrito e Itálico básicos
          parsed = parsed.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\*(.*?)\*/g, '<em>$1</em>');
          
          // Engine Auto-Linkify (Força target="_blank")
          const urlRegex = /(https?:\/\/[^\s]+)/g;
          parsed = parsed.replace(urlRegex, function(url) {
            return `<a href="${url}" target="_blank" rel="noopener noreferrer" style="color: var(--blue); text-decoration: underline;">${url}</a>`;
          });

          preview.innerHTML = parsed;
        }

        window.alternarModoMural = function() {
          isEditMode = !isEditMode;
          if (isEditMode) {
            textarea.style.display = 'block';
            preview.style.display = 'none';
            btnModo.innerHTML = '<span class="material-icons" style="font-size:16px;">visibility</span> Preview';
            btnModo.style.color = 'var(--text-secondary)';
            btnModo.style.borderColor = 'rgba(255,255,255,0.1)';
            textarea.focus();
          } else {
            textarea.style.display = 'none';
            preview.style.display = 'block';
            btnModo.innerHTML = '<span class="material-icons" style="font-size:16px;">edit</span> Editar';
            btnModo.style.color = 'var(--blue)';
            btnModo.style.borderColor = 'var(--blue)';
            renderPreview();
          }
        };

        // UX: Se já houver texto ao abrir a página, inicia direto no Modo Leitura (Preview)
        if (textarea.value.trim() !== '') {
          window.alternarModoMural();
        }

        let timeout;
        textarea.addEventListener('input', () => {
          status.textContent = 'Salvando...';
          status.style.color = 'var(--text-secondary)';
          clearTimeout(timeout);
          timeout = setTimeout(async () => {
            try {
              const res = await fetch('/api/lajeado/mural', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ conteudo: textarea.value })
              });
              if (res.ok) {
                status.textContent = '✓ Salvo na nuvem';
                status.style.color = 'var(--green)';
              } else {
                status.textContent = '❌ Erro ao salvar (Faça login)';
                status.style.color = 'var(--red)';
              }
            } catch(e) {
              status.textContent = '❌ Erro de rede';
              status.style.color = 'var(--red)';
            }
          }, 800);
        });
      });

      // Lógica do Motor WYSIWYG (Visual Editor)
      <% if (typeof user !== 'undefined' && user) { %>
        const dadosRaw = <%- JSON.stringify(dados) %>;
        let lajeadoData = null;

        function toggleLayoutEditMode() {
          if (!lajeadoData) {
            lajeadoData = JSON.parse(JSON.stringify(dadosRaw)); // Deep Clone Seguro
            renderPainelVisual();
            document.getElementById('barSalvarLayout').style.display = 'flex';
          } else {
            if(confirm('Descartar alterações não salvas?')) {
              window.location.reload();
            }
          }
        }

        window.addMes = function(personKey) {
          lajeadoData[personKey].meses.push({ titulo: "Novo Mês", statusLabel: "Atenção", statusClass: "warning", metricas: [] });
          renderPainelVisual();
        }
        window.removeMes = function(personKey, mIdx) {
          if(confirm('Excluir este mês inteiro?')) {
            lajeadoData[personKey].meses.splice(mIdx, 1);
            renderPainelVisual();
          }
        }
        window.addMetrica = function(personKey, mIdx) {
          lajeadoData[personKey].meses[mIdx].metricas.push({ label: "", valor: "R$ 0,00", classe: "blue" });
          renderPainelVisual();
        }
        window.removeMetrica = function(personKey, mIdx, metIdx) {
          lajeadoData[personKey].meses[mIdx].metricas.splice(metIdx, 1);
          renderPainelVisual();
        }

        function renderPainelVisual() {
          const container = document.getElementById('conteudo');
          let html = '';

          ['douglas', 'vitoria'].forEach(personKey => {
            const p = lajeadoData[personKey];
            if (!p) return;
            p.meses = p.meses || [];

            html += `<article class="person-card" style="border: 1px solid var(--blue); box-shadow: 0 0 0 2px rgba(56,120,225,0.2);">`;
            html += `
            <header class="person-header" style="background: rgba(56, 120, 225, 0.05); border-bottom: 1px solid rgba(56, 120, 225, 0.2);">
              <div class="person-title-row">
                <input class="edit-input" style="font-size: 1.4rem; font-weight: bold; flex: 1;" value="${p.nome}" onchange="lajeadoData['${personKey}'].nome=this.value">
                <input class="edit-input tag-input" style="width: 180px;" value="${p.tag}" onchange="lajeadoData['${personKey}'].tag=this.value">
              </div>
              <div class="person-stats">
                <div class="person-stat"><small>Guardado</small><input class="edit-input" value="${p.resumo.guardado}" onchange="lajeadoData['${personKey}'].resumo.guardado=this.value"></div>
                <div class="person-stat"><small>Saque aniversário</small><input class="edit-input" value="${p.resumo.saque}" onchange="lajeadoData['${personKey}'].resumo.saque=this.value"></div>
                <div class="person-stat"><small>Total</small><input class="edit-input" value="${p.resumo.total}" onchange="lajeadoData['${personKey}'].resumo.total=this.value"></div>
              </div>
            </header>
            <div class="person-body">
              <div class="month-list">
            `;

            p.meses.forEach((mes, mIdx) => {
              mes.metricas = mes.metricas || [];
              html += `
              <section class="month-card" style="border: 1px dashed rgba(255,255,255,0.2); background: rgba(0,0,0,0.15);">
                <div class="month-top" style="flex-wrap: wrap; gap: 12px; margin-bottom: 16px;">
                  <input class="edit-input" style="flex:1; min-width: 140px; font-weight: bold;" value="${mes.titulo}" onchange="lajeadoData['${personKey}'].meses[${mIdx}].titulo=this.value">
                  <div style="display:flex; gap: 8px;">
                    <input class="edit-input" style="width: 110px; font-size: 0.8rem;" placeholder="Status (Atenção)" value="${mes.statusLabel}" onchange="lajeadoData['${personKey}'].meses[${mIdx}].statusLabel=this.value">
                    <select class="edit-input" style="width: 110px; font-size: 0.8rem;" onchange="lajeadoData['${personKey}'].meses[${mIdx}].statusClass=this.value">
                      <option value="success" ${mes.statusClass==='success'?'selected':''}>Verde</option>
                      <option value="warning" ${mes.statusClass==='warning'?'selected':''}>Amarelo</option>
                      <option value="info" ${mes.statusClass==='info'?'selected':''}>Azul</option>
                      <option value="danger" ${mes.statusClass==='danger'?'selected':''}>Vermelho</option>
                    </select>
                    <button onclick="removeMes('${personKey}', ${mIdx})" class="btn-del" title="Excluir Mês"><span class="material-icons" style="font-size:18px;">delete</span></button>
                  </div>
                </div>
                <div class="month-metrics" style="display:grid; gap:8px;">
              `;

              mes.metricas.forEach((met, metIdx) => {
                html += `
                <div class="metric" style="gap:8px; padding-bottom:8px; border-bottom: 1px solid rgba(255,255,255,0.05); display:flex; align-items:center;">
                  <input class="edit-input" placeholder="Nova conta" value="${met.label}" onchange="lajeadoData['${personKey}'].meses[${mIdx}].metricas[${metIdx}].label=this.value" style="flex:1;">
                  <input class="edit-input" placeholder="R$ 0,00" value="${met.valor}" onchange="lajeadoData['${personKey}'].meses[${mIdx}].metricas[${metIdx}].valor=this.value" style="width:100px;">
                  <select class="edit-input" onchange="lajeadoData['${personKey}'].meses[${mIdx}].metricas[${metIdx}].classe=this.value" style="width:100px;">
                    <option value="blue" ${met.classe==='blue'?'selected':''}>Azul</option>
                    <option value="red" ${met.classe==='red'?'selected':''}>Vermelho</option>
                    <option value="green" ${met.classe==='green'?'selected':''}>Verde</option>
                  </select>
                  <button onclick="removeMetrica('${personKey}', ${mIdx}, ${metIdx})" class="btn-del" title="Remover"><span class="material-icons" style="font-size:18px;">close</span></button>
                </div>`;
              });
              html += `<div style="text-align:center; margin-top:8px;"><button class="btn-add" onclick="addMetrica('${personKey}', ${mIdx})">+ Nova Linha (Métrica)</button></div>`;
              html += `</div></section>`;
            });
            html += `<div style="text-align:center; margin-top:20px;"><button class="btn-add primary" onclick="addMes('${personKey}')">+ Adicionar Novo Mês</button></div>`;
            html += `</div></div></article>`;
          });
          container.innerHTML = html;
        }

        async function salvarLayoutDados() {
          const btn = document.getElementById('btnSalvarLajeado');
          const originalText = btn.innerText;
          btn.innerText = 'Salvando...';
          try {
            const res = await fetch('/api/lajeado', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ dados: lajeadoData })
            });
            if(res.ok) window.location.reload();
            else { alert('Erro ao salvar no servidor.'); btn.innerText = originalText; }
          } catch(e) {
            alert('Erro de rede: ' + e.message);
            btn.innerText = originalText;
          }
        }
      <% } %>
    </script>
  </body>
</html>