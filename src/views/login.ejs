<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Login - Gestão Financeira</title>

    <!-- Meta Tags para Preview Social (Open Graph / WhatsApp / Telegram) -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Login - Gestão Financeira">
    <meta property="og:description" content="Acesse sua conta para gerenciar suas contas a pagar de forma simples e segura.">
    <meta property="og:image" content="https://contas-a-pagar-nsti.onrender.com/icons/icon-512x512.png">
    <meta property="og:url" content="https://contas-a-pagar-nsti.onrender.com/login">
    <meta property="og:site_name" content="Gestão Financeira">

    <!-- Twitter Card Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Login - Gestão Financeira">
    <meta name="twitter:description" content="Acesse sua conta para gerenciar suas contas a pagar.">
    <meta name="twitter:image" content="https://contas-a-pagar-nsti.onrender.com/icons/icon-512x512.png">

    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2"/> 
    <link rel="stylesheet" href="/css/style.css?v=2">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body class="login-body">

    <div class="login-container">
        <div class="login-card">
            
            <div class="login-icon">
                <span class="material-icons">lock</span>
            </div>

            <h2>Bem-vindo de volta</h2>
            <span class="login-subtitle">Gerencie suas finanças com segurança</span>

            <% if (error) { %>
            <div class="error-msg">
                <span class="material-icons" style="font-size: 14px; vertical-align: middle; margin-right: 5px;">error</span>
                <%= error %>
            </div>
            <% } %>

            <form action="/login" method="POST" class="login-form" id="loginForm">
                <div class="form-group">
                    <label for="password">Digite sua senha de acesso</label>
                    <input 
                        type="password" 
                        name="password" 
                        id="password" 
                        class="login-input" 
                        placeholder="••••••••" 
                        required 
                        autofocus
                        autocomplete="current-password"
                    >
                </div>
                
                <!-- Checkbox Lembrar de Mim -->
                <div class="remember-group">
                    <label class="custom-checkbox-wrapper" for="lembrar">
                        <input type="checkbox" name="lembrar" id="lembrar" value="on" class="hidden-checkbox">
                        <div class="custom-checkbox"></div>
                        <span class="remember-text">Lembrar de mim</span>
                    </label>
                </div>

                <button type="submit" class="login-btn">
                    <span class="material-icons" style="font-size: 18px; margin-right: 8px;">login</span>
                    Entrar no Sistema
                </button>
            </form>

            <div class="login-footer">
                &copy; <%= new Date().getFullYear() %> Gestão Financeira • Acesso Seguro
            </div>
        </div>
    </div>

    <script>
        // Log de debug no console do navegador
        console.log('[LOGIN PAGE] Loaded');
        console.log('[LOGIN PAGE] Form action:', document.getElementById('loginForm')?.action);
        
        // Monitora submit do form
        document.getElementById('loginForm')?.addEventListener('submit', (e) => {
            const password = document.getElementById('password')?.value;
            const lembrar = document.getElementById('lembrar')?.checked;
            
            console.log('[LOGIN FORM] Submit triggered');
            console.log('[LOGIN FORM] Password length:', password?.length);
            console.log('[LOGIN FORM] Remember me:', lembrar);
            
            // Não previne o submit - deixa o form fazer POST tradicional
        });
    </script>
</body>
</html>