<header>
    <div class="header-left">
        <h1>Painel de <%= nav.atual.dateObj.toLocaleString('pt-BR', { month: 'long', year: 'numeric' }) %></h1>
        <div class="nav-links">
            <a href="/?month=<%= nav.ant.month %>&year=<%= nav.ant.year %>" class="nav-btn">‹ Anterior</a>
            <a href="/" class="nav-btn <%= (!query.month) ? 'active' : '' %>">Mês Atual</a>
            <a href="/?month=<%= nav.prox.month %>&year=<%= nav.prox.year %>" class="nav-btn">Próximo ›</a>
        </div>
    </div>

</header>