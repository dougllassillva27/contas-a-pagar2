<header>
    <div class="header-left">
        <h1 style="display: flex; align-items: center; gap: 8px;">
            Painel de <%= nav.atual.dateObj.toLocaleString('pt-BR', { month: 'long', year: 'numeric' }) %>
            <% if (typeof mesFechado !== 'undefined' && mesFechado) { %>
                <span class="material-icons" style="color: var(--red);" title="Mês Fechado">lock</span>
            <% } %>
        </h1>
        <div class="nav-links">
            <a href="<%= typeof currentPath !== 'undefined' ? currentPath : '/' %>?month=<%= nav.ant.month %>&year=<%= nav.ant.year %>" class="nav-btn">‹ Anterior</a>
            <a href="<%= typeof currentPath !== 'undefined' ? currentPath : '/' %>" class="nav-btn <%= (typeof query === 'undefined' || !query.month) ? 'active' : '' %>">Mês Atual</a>
            <a href="<%= typeof currentPath !== 'undefined' ? currentPath : '/' %>?month=<%= nav.prox.month %>&year=<%= nav.prox.year %>" class="nav-btn">Próximo ›</a>
        </div>
    </div>

</header>