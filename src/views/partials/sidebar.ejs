<!-- src/views/partials/sidebar.ejs -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="fecharSidebar()"></div>

<nav id="mobileSidebar" class="sidebar-mobile">
    <div class="sidebar-header">
        <h2>Menu</h2>
        <button class="btn-close-sidebar" onclick="fecharSidebar()">
            <span class="material-icons">close</span>
        </button>
    </div>
    
    <div class="sidebar-actions">
        <% if (user.id === 1) { %> 
            <a href="/switch/2" class="sidebar-btn sidebar-btn-users">
                <span class="material-icons" style="color: var(--orange);">people</span> Vitória
            </a>
        <% } else { %>
            <a href="/switch/1" class="sidebar-btn sidebar-btn-users">
                <span class="material-icons" style="color: var(--blue);">people</span> Dodo
            </a>
        <% } %>

        <button class="sidebar-btn" onclick="fecharSidebarE(abrirModalUltimas)">
            <span class="material-icons">history</span> Últimas
        </button>

        <a href="/terceiros?month=<%= nav.atual.month %>&year=<%= nav.atual.year %>" target="_blank" class="sidebar-btn" onclick="fecharSidebar()">
            <span class="material-icons" style="color: var(--green);">share</span> Terceiros
        </a>

        <button class="sidebar-btn" onclick="fecharSidebarE(abrirModalCalcularLuz)">
            <span class="material-icons" style="color: var(--yellow);">lightbulb</span> Calcular Luz
        </button>

        <button class="sidebar-btn" onclick="fecharSidebarE(() => abrirConfirmacaoAcao('COPIAR'))">
            <span class="material-icons">content_copy</span> Copiar Contas
        </button>
        
        <a href="/relatorio?month=<%= nav.atual.month %>&year=<%= nav.atual.year %>" target="_blank" class="sidebar-btn" onclick="fecharSidebar()">
            <span class="material-icons">print</span> Imprimir
        </a>

        <div class="sidebar-divider"></div>

        <button class="sidebar-btn" onclick="fecharSidebarE(toggleMesFechado)" id="btnToggleMes">
            <% if (typeof mesFechado !== 'undefined' && mesFechado) { %>
                <span class="material-icons" style="color: var(--blue);">lock_open</span> Reabrir Mês
            <% } else { %>
                <span class="material-icons" style="color: var(--red);">lock</span> Fechar Mês
            <% } %>
        </button>

        <button class="sidebar-btn btn-danger-sidebar" onclick="fecharSidebarE(() => abrirConfirmacaoAcao('DELETAR'))">
            <span class="material-icons">delete</span> Deletar Mês
        </button>

        <a href="/logout" class="sidebar-btn btn-danger-sidebar">
            <span class="material-icons">logout</span> Sair
        </a>
    </div>

    <!-- SEÇÃO DE ATALHOS -->
    <div class="sidebar-shortcuts" style="margin: 20px 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.1);">
        <h4 style="color: var(--text-secondary); font-size: 0.75rem; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;">Atalhos</h4>
        <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.85rem;">
            <li style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
                <span style="color: var(--text-muted);">Últimas Adições</span>
                <kbd style="background: rgba(255,255,255,0.1); color: var(--text-main); padding: 3px 6px; border-radius: 4px; font-size: 0.7rem; font-family: monospace;">Alt + A</kbd>
            </li>
            <li style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
                <span style="color: var(--text-muted);">Novo Lançamento</span>
                <kbd style="background: rgba(255,255,255,0.1); color: var(--text-main); padding: 3px 6px; border-radius: 4px; font-size: 0.7rem; font-family: monospace;">Alt + N</kbd>
            </li>
            <li style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
                <span style="color: var(--text-muted);">Gestão Terceiros</span>
                <kbd style="background: rgba(255,255,255,0.1); color: var(--text-main); padding: 3px 6px; border-radius: 4px; font-size: 0.7rem; font-family: monospace;">Alt + T</kbd>
            </li>
            <li style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
                <span style="color: var(--text-muted);">Backup JSON</span>
                <kbd style="background: rgba(255,255,255,0.1); color: var(--text-main); padding: 3px 6px; border-radius: 4px; font-size: 0.7rem; font-family: monospace;">Alt + B</kbd>
            </li>
            <li style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
                <span style="color: var(--text-muted);">Fechar Mês</span>
                <kbd style="background: rgba(255,255,255,0.1); color: var(--text-main); padding: 3px 6px; border-radius: 4px; font-size: 0.7rem; font-family: monospace;">Alt + C</kbd>
            </li>
            <li style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
                <span style="color: var(--text-muted);">Relatório</span>
                <kbd style="background: rgba(255,255,255,0.1); color: var(--text-main); padding: 3px 6px; border-radius: 4px; font-size: 0.7rem; font-family: monospace;">Alt + I</kbd>
            </li>
            <li style="display: flex; align-items: center; justify-content: space-between;">
                <span style="color: var(--text-muted);">Fechar Modais</span>
                <kbd style="background: rgba(255,255,255,0.1); color: var(--text-main); padding: 3px 6px; border-radius: 4px; font-size: 0.7rem; font-family: monospace;">Esc</kbd>
            </li>
        </ul>
    </div>
</nav>

<!-- FAB (Botão Flutuante) Hamburger -->
<button class="fab-menu" id="fabMenu" onclick="abrirSidebar()">
    <span class="material-icons">menu</span>
</button>
