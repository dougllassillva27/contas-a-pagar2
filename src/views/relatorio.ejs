<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %></title>

    <!-- Meta Tags para Preview Social -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= titulo %>">
    <meta property="og:description" content="Portal de acompanhamento de contas a pagar (Fixas e Cartão).">
    <meta property="og:image" content="https://contas-a-pagar-nsti.onrender.com/icons/icon-512x512.png">
    <meta property="og:url" content="https://contas-a-pagar-nsti.onrender.com/relatorio">
    <meta property="og:site_name" content="Gestão Financeira">
    
    <!-- Bibliotecas Externas -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    <style>
        /* CSS Reset & Variáveis (Dark Mode Integrado) */
        :root {
            --bg-body: #121212;
            --bg-card: #1e1e1e;
            --bg-input: #2c2c2c;
            --text-main: #ffffff;
            --text-muted: #a0a0a0;
            --primary: #3878e1;
            --success: #66bb6a;
            --warning: #ffa726;
            --border: rgba(255, 255, 255, 0.05); /* Match com o border-bottom do style.css original */
            --radius: 16px;
        }
        
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-card); border-radius: 4px; }
        ::-webkit-scrollbar-thumb { background-color: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background-color: var(--primary); }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-body);
            color: var(--text-main);
            margin: 0;
            padding: 40px 20px;
        }

        /* Removido o max-width para tela cheia e dinâmica */
        .container {
            width: 100%;
            margin: 0 auto;
        }

        /* Top Grid Principais (Visão Estratégica) */
        .top-grid {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 20px;
            margin-bottom: 30px;
        }
        
        @media (max-width: 768px) {
            .top-grid { grid-template-columns: 1fr; }
        }

        .card {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 28px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3); /* Sombra Dark do projeto principal */
            border: 1px solid var(--border);
        }

        .header-content h1 {
            margin: 0;
            font-size: 32px;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: -0.5px;
        }

        .header-content .meta {
            color: var(--text-muted);
            font-size: 15px;
            margin-top: 6px;
            margin-bottom: 25px;
        }

        .total-badge-container {
            margin-top: auto;
        }
        
        .total-label {
            font-size: 13px;
            text-transform: uppercase;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 0.5px;
        }

        .total-value {
            font-size: 42px;
            font-weight: 700;
            color: var(--text-main);
            line-height: 1.1;
            margin-top: 4px;
        }

        /* Container do Canvas do Gráfico */
        .chart-container-card {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 15px;
        }
        .chart-container {
            position: relative;
            width: 100%;
            height: 200px;
        }

        /* Layout Grid da Lista de Pessoas (Maximizando espaço) */
        #pessoas-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(600px, 1fr));
            gap: 20px;
            align-items: start;
        }
        @media (max-width: 650px) {
            #pessoas-container { grid-template-columns: 1fr; }
        }

        /* Lista de Pessoas (Cards agrupados) */
        .person-card {
            background: var(--bg-card);
            border-radius: var(--radius);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border);
            overflow: hidden;
            page-break-inside: avoid;
            transition: transform 0.2s;
        }

        .person-header {
            background: rgba(0, 0, 0, 0.2);
            padding: 18px 26px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .person-name {
            font-size: 18px;
            font-weight: 600;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-main);
        }

        .person-dot {
            display: inline-block;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: var(--primary); /* Dinâmico via JS Chart */
        }

        .person-total {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-main);
        }

        /* Tabela Estilizada Minimalista */
        .list-table {
            width: 100%;
            border-collapse: collapse;
        }

        .list-table th {
            text-align: left;
            padding: 14px 26px;
            background: transparent;
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--border);
        }

        .list-table td {
            padding: 18px 26px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
            font-size: 14px;
            transition: background-color 0.2s;
        }

        .list-table tr:last-child td {
            border-bottom: none;
        }

        .list-table tr:hover td {
            background: rgba(255, 255, 255, 0.03);
        }

        /* Custom Checkbox Interativa */
        .checkbox-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .custom-checkbox {
            appearance: none;
            width: 22px;
            height: 22px;
            border: 2px solid #555;
            border-radius: 6px;
            cursor: pointer;
            position: relative;
            transition: all 0.2s ease;
            margin: 0;
            display: block;
            background: var(--bg-input);
        }

        .custom-checkbox:hover {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(56, 120, 225, 0.15);
        }

        .custom-checkbox:checked {
            background-color: var(--success);
            border-color: var(--success);
        }

        .custom-checkbox:checked::after {
            content: '';
            position: absolute;
            left: 6px;
            top: 3px;
            width: 5px;
            height: 10px;
            border: solid white;
            border-width: 0 2px 2px 0;
            transform: rotate(45deg);
        }
        
        .item-desc {
            font-weight: 500;
            color: var(--text-main);
            transition: color 0.2s;
        }

        .item-parcela {
            display: inline-block;
            margin-left: 10px;
            padding: 3px 8px;
            border-radius: 12px;
            background: #333;
            color: var(--text-muted);
            font-size: 11px;
            font-weight: 600;
        }

        .item-valor {
            font-weight: 600;
            text-align: right;
            color: var(--text-main);
            white-space: nowrap;
        }

        /* Visual de Status e Desativado (Linha Riscada e Diminuida) */
        .tr-conferido td {
            background-color: rgba(0, 0, 0, 0.15);
        }
        .tr-conferido .item-desc {
            text-decoration: line-through;
            color: #666;
        }
        .tr-conferido .item-valor {
            color: #666;
        }

        .badge-status {
            font-size: 11px;
            padding: 5px 12px;
            border-radius: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }
        .badge-pago {
            background: rgba(102, 187, 106, 0.15);
            color: var(--success);
        }
        .badge-pendente {
            background: rgba(255, 167, 38, 0.15);
            color: var(--warning);
        }

        /* Botões de Ação Flutuantes (Excel e Impressora) */
        .actions-bar {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 50;
        }

        .btn-action {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            border: none;
            background: var(--bg-card);
            color: var(--text-main);
            font-size: 22px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }
        
        .btn-action:hover {
            transform: translateY(-4px);
            background: #333;
            box-shadow: 0 14px 20px -3px rgba(0, 0, 0, 0.6);
        }

        .btn-primary {
            background: var(--primary);
            color: white;
            width: 64px;
            height: 64px;
            font-size: 26px;
        }
        .btn-primary:hover {
            background: #2b62c0;
        }

        .footer {
            text-align: center;
            margin-top: 50px;
            color: var(--text-muted);
            font-size: 13px;
        }

        /* --- Menu de Contexto --- */
        .context-menu {
            position: fixed;
            z-index: 10000;
            background: #2a2a2a;
            border: 1px solid #444;
            border-radius: 8px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6);
            padding: 6px 0;
            min-width: 240px;
            user-select: none;
            display: none;
        }
        .context-menu ul {
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .context-menu li {
            padding: 12px 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.95rem;
            color: #eee;
            transition: background 0.2s;
        }
        .context-menu li:hover {
            background: #3a3a3a;
        }
        .context-menu li .material-icons {
            font-size: 20px;
        }

        /* Folha de Estilo para Impressão e Geração de PDF Enxuta */
        @media print {
            body { 
                background: white !important; 
                padding: 0;
            }
            .container {
                max-width: 100%;
            }
            #pessoas-container {
                display: block; /* Disable grid for linear printing */
            }
            .card, .person-card {
                box-shadow: none !important;
                border: 1px solid #ddd !important;
                background: white !important;
                margin-bottom: 20px;
            }
            .header-content h1, .person-name, .person-total, .total-value, .item-desc, .item-valor {
                color: #000 !important;
            }
            .person-header {
                background: #f0f0f0 !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            .chart-container-card, .actions-bar, .context-menu {
                display: none !important;
            }
            .list-table th {
                color: #000;
                border-bottom: 2px solid #000;
            }
            .custom-checkbox {
                border-color: #000;
                background: white !important;
            }
            .custom-checkbox:checked {
                background-color: white !important;
                border-color: #000 !important;
            }
            .custom-checkbox:checked::after {
                border-color: #000;
            }
            .badge-status {
                border: 1px solid #000;
                background: transparent !important;
                color: #000 !important;
            }
            .item-parcela {
                background: transparent !important;
                border: 1px solid #aaa;
                color: #000;
            }
            .tr-conferido .item-desc {
                text-decoration: none; /* Mantêm o texto visível na impressão */
                color: #000 !important;
            }
            .tr-conferido .item-valor {
                color: #000 !important;
            }
        }
    </style>
</head>
<body>

    <!-- Botões Flutuantes -->
    <div class="actions-bar no-print">
        <button class="btn-action" onclick="exportDataToExcel()" title="Exportar dados para Excel (.xlsx)">📊</button>
        <button class="btn-action btn-primary" onclick="window.print()" title="Salvar em PDF ou Imprimir">🖨️</button>
    </div>

    <div class="container">
        <!-- Dashboard Top / Resumo Analítico -->
        <div class="top-grid">
            <div class="card header-content" style="display: flex; flex-direction: column;">
                <div>
                    <h1>Extrato Mensal</h1>
                    <div class="meta">Referência de Faturamento: <%= mes %> <%= ano %></div>
                </div>
                
                <div class="total-badge-container">
                    <div class="total-label">Gasto Total Projetado</div>
                    <div class="total-value">R$ <%= Number(totalGeral).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
                </div>
            </div>

            <!-- Gráfico Dinâmico D3/Canvas -->
            <div class="card chart-container-card">
                <div class="chart-container">
                    <canvas id="gastosChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Mapeamento dos Cartões Analíticos Pessoais (Agora em Grid Full-Width) -->
        <div id="pessoas-container">
            <% Object.keys(dados).forEach((pessoa, index) => { 
                const grupo = dados[pessoa];
                if (grupo.itens.length > 0) {
            %>
                <div class="person-card" data-person="<%= pessoa %>">
                    <div class="person-header">
                        <h2 class="person-name">
                            <span class="person-dot" data-index="<%= index %>"></span>
                            <%= pessoa %>
                        </h2>
                        <span class="person-total">R$ <%= Number(grupo.total).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></span>
                    </div>

                    <table class="list-table">
                        <thead>
                            <tr>
                                <th style="width: 60px; text-align: center;" title="Marcar como conferido">✓</th>
                                <th>Despesa / Parcelamento</th>
                                <th style="width: 120px; text-align: center;">Status</th>
                                <th style="text-align: right;">Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% grupo.itens.forEach(item => { %>
                                <!-- Salvamos o status original no data attribute para podermos voltar se o usuário desmarcar -->
                                <tr class="<%= item.conferidoextrato ? 'tr-conferido' : '' %>" data-original-status="<%= item.status %>" data-id="<%= item.id %>">
                                    <td style="text-align: center;">
                                        <div class="checkbox-wrapper">
                                            <input type="checkbox" class="custom-checkbox chk-conferido" 
                                                   data-id="<%= item.id %>" 
                                                   title="Marque para confirmar a conferência deste valor."
                                                   <%= item.conferidoextrato ? 'checked' : '' %>>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="item-desc"><%= item.descricao %></span>
                                        <% if(item.parcelaatual && item.totalparcelas) { %>
                                            <span class="item-parcela">
                                                <%= String(item.parcelaatual).padStart(2,'0') %> / <%= String(item.totalparcelas).padStart(2,'0') %>
                                            </span>
                                        <% } %>
                                    </td>
                                    <td style="text-align: center;">
                                        <% 
                                            // Lógica Dinâmica: Se estiver CONFERIDO ou PAGO exibe validado verde, senão amarelo
                                            const isCheckedOuPago = item.conferidoextrato || item.status === 'PAGO';
                                        %>
                                        <span class="badge-status <%= isCheckedOuPago ? 'badge-pago' : 'badge-pendente' %> badge-dinamico">
                                            <%= item.conferidoextrato ? 'Conferido' : (item.status === 'PAGO' ? 'Pago' : 'Pendente') %>
                                        </span>
                                    </td>
                                    <td class="item-valor">
                                        R$ <%= Number(item.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } }) %>
        </div>

        <div class="footer">
            Extrato Analítico consolidado e exportado via Gestão Financeira • Data do Sistema: <%= new Date().toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' }) %> às <%= new Date().toLocaleTimeString('pt-BR', { timeZone: 'America/Sao_Paulo' }) %>
        </div>
    </div>

    <!-- HTML do Menu de Contexto para Ações em Lote -->
    <div id="relatorioContextMenu" class="context-menu no-print">
        <ul>
            <li onclick="executarAcaoConferenciaLote(true)">
                <span class="material-icons" style="color: #66bb6a;">check_circle</span>
                Marcar TODAS como Conferidas
            </li>
            <li onclick="executarAcaoConferenciaLote(false)">
                <span class="material-icons" style="color: #ef5350;">cancel</span>
                Desmarcar TODAS
            </li>
        </ul>
    </div>

    <!-- Scripts de Interatividade e Funcionalidade -->
    <script>
        // Dados provindos em tempo de compilação renderizados para JS Limpo
        const dadosRaw = <%- JSON.stringify(dados) %>;
        const totalFaturaStr = "<%= Number(totalGeral).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>";

        // Paleta Dark Mode vibrante ajustada ao contexto
        const colorPalette = [
            '#3878e1', '#66bb6a', '#ffa726', '#ab47bc', '#ec407a', '#26a69a', '#5c6bc0', '#ff7043'
        ];

        document.addEventListener('DOMContentLoaded', () => {
            initChart();
            listenToCheckboxes();
            listenForRightClick();
        });

        // ==========================================
        // Chart.js : Inicialização do Gráfico Rosca
        // ==========================================
        function initChart() {
            const labels = [];
            const dataValues = [];
            let colorIndex = 0;
            const bgColors = [];

            // Povoando labels e valores para o Gráfico
            Object.keys(dadosRaw).forEach((pessoa, i) => {
                if (dadosRaw[pessoa].itens.length > 0) {
                    labels.push(pessoa);
                    dataValues.push(dadosRaw[pessoa].total);
                    
                    const color = colorPalette[colorIndex % colorPalette.length];
                    bgColors.push(color);
                    
                    // Colore a bolinha de identificação do cartão correspondente na view
                    const dot = document.querySelector(`.person-dot[data-index="${i}"]`);
                    if(dot) {
                        dot.style.background = color;
                    }
                    colorIndex++;
                }
            });

            // Fallback de erro se 0 lançamentos
            if(dataValues.reduce((a, b) => a + b, 0) === 0) return;

            const ctx = document.getElementById('gastosChart').getContext('2d');
            
            // Registrando pequeno plugin para preencher o centro do Doughnut
            Chart.register({
                id: 'centerTextPlugin',
                beforeDraw: function(chart) {
                    if (chart.config.type !== 'doughnut') return;
                    const { width, height, ctx } = chart;
                    ctx.restore();
                    
                    const fontSize = (height / 140).toFixed(2);
                    ctx.font = `bold ${fontSize}em Inter`;
                    ctx.textBaseline = "middle";
                    ctx.fillStyle = "#a0a0a0"; // text-muted em dark mode

                    const text = "Distribuição";
                    const textX = Math.round((width - ctx.measureText(text).width) / 2);
                    const textY = height / 2;

                    ctx.fillText(text, textX, textY);
                    ctx.save();
                }
            });

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: dataValues,
                        backgroundColor: bgColors,
                        borderWidth: 0,
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '72%',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            padding: 12,
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            titleFont: { family: 'Inter', size: 14 },
                            bodyFont: { family: 'Inter', size: 14, weight: 'bold' },
                            callbacks: {
                                label: function(context) {
                                    return ` R$ ${context.parsed.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}`;
                                }
                            }
                        }
                    }
                }
            });
        }

        // ==============================================================
        // Conferência Interativa Assíncrona via PATCH com Backend Moderno
        // ==============================================================
        function listenToCheckboxes() {
            const checkboxes = document.querySelectorAll('.chk-conferido');
            
            checkboxes.forEach(chk => {
                chk.addEventListener('change', async (e) => {
                    const id = e.target.dataset.id;
                    const conferido = e.target.checked;
                    const tr = e.target.closest('tr');
                    const badge = tr.querySelector('.badge-dinamico');
                    const statusOriginal = tr.dataset.originalStatus; 
                    
                    // Design Otimista (aplica instantaneamente e corrige visual da cor do Status)
                    if (conferido) {
                        tr.classList.add('tr-conferido');
                        badge.className = 'badge-status badge-pago badge-dinamico';
                        badge.textContent = 'Conferido';
                    } else {
                        tr.classList.remove('tr-conferido');
                        
                        // Retorna o status visual original que veio do banco
                        if(statusOriginal === 'PAGO') {
                            badge.className = 'badge-status badge-pago badge-dinamico';
                            badge.textContent = 'Pago';
                        } else {
                            badge.className = 'badge-status badge-pendente badge-dinamico';
                            badge.textContent = 'Pendente';
                        }
                    }

                    try {
                        const response = await fetch(`/api/lancamentos/${id}/conferido-extrato`, {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ conferido: conferido })
                        });

                        if (!response.ok) throw new Error('Falha no Servidor');
                        
                    } catch (error) {
                        console.error('Falha de sincronização:', error);
                        // Sistema auto-curativo: Rollback visual em caso de erro na rede ou banco
                        e.target.checked = !conferido;
                        if (!conferido) {
                            tr.classList.add('tr-conferido');
                            badge.className = 'badge-status badge-pago badge-dinamico';
                            badge.textContent = 'Conferido';
                        } else {
                            tr.classList.remove('tr-conferido');
                            if(statusOriginal === 'PAGO') {
                                badge.className = 'badge-status badge-pago badge-dinamico';
                                badge.textContent = 'Pago';
                            } else {
                                badge.className = 'badge-status badge-pendente badge-dinamico';
                                badge.textContent = 'Pendente';
                            }
                        }
                        alert('Oops! Houve uma falha de conexão e o status de conferência não foi salvo.');
                    }
                });
            });
        }

        // ==========================================================
        // SheetJS: Geração Executiva Local em Excel
        // ==========================================================
        function exportDataToExcel() {
            try {
                const linhasProcessadas = [];
                
                linhasProcessadas.push(["Relatório Base:", "Extrato Mensal <%= mes %> <%= ano %>"]);
                linhasProcessadas.push(["Gasto Total (R$)", totalFaturaStr]);
                linhasProcessadas.push(["Gerado em:", new Date().toLocaleDateString('pt-BR')]);
                linhasProcessadas.push([]);
                linhasProcessadas.push([]);

                linhasProcessadas.push(['Proprietário', 'Descrição', 'Parcela Ocorrida', 'Total de Parcelas', 'Valor Gasto (R$)', 'Status Operacional', 'Validado (Conferido)']);

                Object.keys(dadosRaw).forEach(pessoa => {
                    const grupo = dadosRaw[pessoa];
                    grupo.itens.forEach(item => {
                        const _parcelaAt = item.parcelaatual || '';
                        const _parcelaTot = item.totalparcelas || '';
                        const _validado = item.conferidoextrato ? 'SIM (Validado)' : 'Não conferido';
                        
                        linhasProcessadas.push([
                            pessoa,
                            item.descricao,
                            _parcelaAt,
                            _parcelaTot,
                            Number(item.valor),
                            item.status,
                            _validado
                        ]);
                    });
                });

                const ws = XLSX.utils.aoa_to_sheet(linhasProcessadas);
                
                const range = XLSX.utils.decode_range(ws['!ref']);
                for (let r = 5; r <= range.e.r; ++r) { 
                    const celulaAlvo = XLSX.utils.encode_cell({c: 4, r: r});
                    if(ws[celulaAlvo]) ws[celulaAlvo].z = '"R$" #,##0.00'; 
                }

                ws['!autofilter'] = { ref: `A6:G${range.e.r + 1}` };

                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, "Faturas Pormenorizadas");
                
                const nomeArquivoSeguro = `Extrato_Mensal_<%= mes %>_<%= ano %>.xlsx`.replace(/ /g, '_');
                XLSX.writeFile(wb, nomeArquivoSeguro);
                
            } catch (err) {
                console.error("Crash SheetJS:", err);
                alert("Falha na formatação da planilha. Verifique o console.");
            }
        }

        // ==============================================================
        // Menu de Contexto Global (Ações em Lote)
        // ==============================================================
        function listenForRightClick() {
            document.addEventListener('contextmenu', (e) => {
                // Previne o menu de abrir caso clique nos botões do topo
                if (e.target.closest('.actions-bar') || e.target.closest('.context-menu')) return;
                
                e.preventDefault();
                abrirMenuRelatorio(e);
            });

            // Fecha o menu se clicar com esquerdo em outro lugar
            document.addEventListener('click', (e) => {
                if (!e.target.closest('#relatorioContextMenu')) {
                    const menu = document.getElementById('relatorioContextMenu');
                    if (menu) menu.style.display = 'none';
                }
            });
        }

        function abrirMenuRelatorio(e) {
            const menu = document.getElementById('relatorioContextMenu');
            menu.style.display = 'block';
            
            let x = e.clientX;
            let y = e.clientY;

            // Evita que o menu abra fora dos limites da tela
            if (x + menu.offsetWidth > window.innerWidth) {
                x = window.innerWidth - menu.offsetWidth - 5;
            }
            if (y + menu.offsetHeight > window.innerHeight) {
                y = window.innerHeight - menu.offsetHeight - 5;
            }

            menu.style.left = `${x}px`;
            menu.style.top = `${y}px`;
        }

        async function executarAcaoConferenciaLote(conferidoStatus) {
            document.getElementById('relatorioContextMenu').style.display = 'none';
            
            // Busca TODAS as checkboxes do relatório (Global)
            const checkboxes = document.querySelectorAll('.chk-conferido');
            const ids = Array.from(checkboxes).map(chk => chk.dataset.id).filter(id => id);

            if (ids.length === 0) return;

            // 1. UI Otimista Instantânea (Aplica a classe a todas as trs)
            checkboxes.forEach(chk => {
                chk.checked = conferidoStatus;
                const tr = chk.closest('tr');
                if (tr) {
                    const badge = tr.querySelector('.badge-dinamico');
                    const statusOriginal = tr.dataset.originalStatus;
                    
                    if (conferidoStatus) {
                        tr.classList.add('tr-conferido');
                        if (badge) {
                            badge.textContent = 'Conferido';
                            badge.className = 'badge-status badge-pago badge-dinamico';
                        }
                    } else {
                        tr.classList.remove('tr-conferido');
                        if (badge) {
                            badge.textContent = statusOriginal === 'PAGO' ? 'Pago' : 'Pendente';
                            badge.className = `badge-status ${statusOriginal === 'PAGO' ? 'badge-pago' : 'badge-pendente'} badge-dinamico`;
                        }
                    }
                }
            });

            // 2. Chamada de Alta Performance para a API
            try {
                const res = await fetch('/api/lancamentos/conferido-extrato-lote', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids, conferido: conferidoStatus })
                });
                
                if (!res.ok) throw new Error('Erro na resposta do servidor');
            } catch (error) {
                console.error('Falha na ação em lote:', error);
                alert('Falha ao sincronizar com o servidor. Por favor, recarregue a página.');
            }
        }
    </script>
</body>
