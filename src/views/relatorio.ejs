    <!-- ✅ NOVO: Menu de Contexto para Ações em Lote -->
    <div id="relatorioContextMenu" class="context-menu">
        <ul>
            <li onclick="executarAcaoConferenciaLote(true)">
                <span class="material-icons" style="color: var(--success);">check_circle</span>
                Marcar Todas como Conferidas
            </li>
            <li onclick="executarAcaoConferenciaLote(false)">
                <span class="material-icons" style="color: var(--warning);">cancel</span>
                Desmarcar Todas
            </li>
        </ul>
    </div>

