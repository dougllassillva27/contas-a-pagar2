<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head') %>
    <style>
        .terceiros-dash-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        .terceiro-dash-card {
            background: var(--surface);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .terceiro-dash-header {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        .terceiro-dash-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: auto;
        }
        .terceiro-dash-actions button {
            padding: 10px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            transition: 0.2s;
        }
        .btn-dash-copiar {
            background: rgba(59, 130, 246, 0.1);
            color: var(--blue);
        }
        .btn-dash-copiar:hover {
            background: rgba(59, 130, 246, 0.2);
        }
        .btn-dash-abrir {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-primary);
        }
        .btn-dash-abrir:hover {
            background: rgba(255, 255, 255, 0.1);
        }
        .btn-dash-whatsapp {
            background: rgba(37, 211, 102, 0.1);
            color: #25D366;
        }
        .btn-dash-whatsapp:hover {
            background: rgba(37, 211, 102, 0.2);
        }
        .btn-dash-numero {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-secondary);
        }
        .btn-dash-numero:hover {
            background: rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body data-month="<%= nav.atual.month %>" data-year="<%= nav.atual.year %>" data-username="<%= user.nome %>" data-userid="<%= user.id %>" data-mes-fechado="<%= mesFechado ? 'true' : 'false' %>">
    <%- include('partials/header') %>

    <div class="panel" style="margin-top: 20px; background: transparent; border: none; padding: 0;">
        <div class="panel-header" style="border-bottom: none; margin-bottom: 0;">
            <h2>Gestão de Links Públicos (Terceiros)</h2>
            <span style="color: var(--text-secondary); font-size: 0.9rem;">Compartilhe o painel de contas</span>
        </div>

        <% if (terceiros && terceiros.length > 0) { %>
            <div class="terceiros-dash-grid">
                <% terceiros.forEach(pessoa => { %>
                    <div class="terceiro-dash-card">
                        <div class="terceiro-dash-header">
                            <span class="material-icons" style="color: #2b62c0;">account_circle</span>
                            <%= pessoa.nome %>
                        </div>
                        
                        <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                            <span style="color: var(--text-secondary);">Total no mês:</span>
                            <strong style="color: var(--text-primary);">R$ <%= Number(pessoa.totalGeral).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></strong>
                        </div>

                        <div class="terceiro-dash-actions">
                            <button class="btn-dash-whatsapp" onclick="enviarWhatsApp('<%= pessoa.nome %>', '<%= pessoa.telefone || '' %>')">
                                <span class="material-icons" style="font-size: 18px;">chat</span> WhatsApp
                            </button>
                            <button class="btn-dash-copiar" onclick="copiarLinkEspecifico('<%= pessoa.nome %>')">
                                <span class="material-icons" style="font-size: 18px;">content_copy</span> Copiar
                            </button>
                            <button class="btn-dash-numero" onclick="editarTelefone('<%= pessoa.nome %>', '<%= pessoa.telefone || '' %>')">
                                <span class="material-icons" style="font-size: 18px;">edit</span> Número
                            </button>
                            <button class="btn-dash-abrir" onclick="abrirLinkEspecifico('<%= pessoa.nome %>')">
                                <span class="material-icons" style="font-size: 18px;">open_in_new</span> Abrir
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 40px; background: var(--surface); border-radius: 12px; margin-top: 20px;">
                <span class="material-icons" style="font-size: 48px; color: var(--text-secondary); opacity: 0.5;">people_outline</span>
                <p style="color: var(--text-secondary); margin-top: 15px;">Nenhum terceiro cadastrado no sistema.</p>
            </div>
        <% } %>
    </div>

    <!-- Modal Editar Telefone -->
    <div id="modalEditarTelefone" class="modal-overlay">
        <div class="modal-container" style="max-width: 400px;">
            <div class="modal-header">
                <h2>Editar WhatsApp</h2>
                <button class="modal-close" onclick="fecharModalEditarTelefone()"><span class="material-icons">close</span></button>
            </div>
            <div class="modal-body">
                <p style="margin-bottom: 15px; color: var(--text-secondary);">Digite o celular (DDD + Número) para <strong id="editTelefoneNomeDisplay" style="color: var(--text-primary);"></strong>:</p>
                <input type="hidden" id="editTelefoneNome" />
                <div class="form-group" style="margin-bottom: 20px; display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 0.9rem; color: var(--text-secondary);">Celular</label>
                    <input type="text" id="editTelefoneInput" class="form-control" placeholder="Ex: 51999999999" style="padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg-color); color: var(--text-primary);" />
                </div>
            </div>
            <div class="modal-footer" style="display: flex; gap: 10px; justify-content: flex-end;">
                <button onclick="fecharModalEditarTelefone()" style="padding: 10px 20px; border: none; border-radius: 8px; background: rgba(255,255,255,0.1); color: var(--text-primary); cursor: pointer; font-weight: 600;">Cancelar</button>
                <button onclick="confirmarSalvarTelefone()" style="padding: 10px 20px; border: none; border-radius: 8px; background: var(--blue); color: #fff; font-weight: 600; cursor: pointer;">Salvar</button>
            </div>
        </div>
    </div>

    <%- include('partials/modals') %>
    <%- include('partials/sidebar') %>

    <script src="/js/app.js"></script>
    <script>
        function obterUrlTerceiro(nome) {
            const userId = document.body.dataset.userid;
            const month = document.body.dataset.month;
            const year = document.body.dataset.year;
            return `${window.location.origin}/contas/${userId}/${encodeURIComponent(nome)}?month=${month}&year=${year}`;
        }

        function copiarLinkEspecifico(nome) {
            const url = obterUrlTerceiro(nome);
            copiarAoClipboard(url);
            mostrarAviso('Sucesso', 'Link de ' + nome + ' copiado para a área de transferência!');
        }

        function abrirLinkEspecifico(nome) {
            const url = obterUrlTerceiro(nome);
            window.open(url, '_blank');
        }

        function editarTelefone(nome, telefoneAtual) {
            let defaultValor = telefoneAtual ? telefoneAtual.replace(/^55/, '') : '';
            
            document.getElementById('editTelefoneNome').value = nome;
            document.getElementById('editTelefoneNomeDisplay').innerText = nome;
            document.getElementById('editTelefoneInput').value = defaultValor;
            
            if (typeof registerModalOpen === 'function') registerModalOpen();
            document.getElementById('modalEditarTelefone').classList.add('active');
            
            setTimeout(() => document.getElementById('editTelefoneInput').focus(), 100);
        }

        function fecharModalEditarTelefone() {
            if (typeof handleModalClose === 'function') handleModalClose();
            document.getElementById('modalEditarTelefone').classList.remove('active');
        }

        async function confirmarSalvarTelefone() {
            const nome = document.getElementById('editTelefoneNome').value;
            const telefone = document.getElementById('editTelefoneInput').value;
            
            fecharModalEditarTelefone();
            if (typeof mostrarLoading === 'function') mostrarLoading();
            
            try {
                const res = await fetch('/api/terceiros/telefone', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nome, telefone })
                });
                
                if (typeof ocultarLoading === 'function') ocultarLoading();
                
                if (res.ok) {
                    if (typeof mostrarAviso === 'function') mostrarAviso('Sucesso', 'Telefone salvo com sucesso!');
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    if (typeof mostrarAviso === 'function') mostrarAviso('Erro', 'Falha ao salvar telefone.');
                }
            } catch (err) {
                console.error(err);
                if (typeof ocultarLoading === 'function') ocultarLoading();
                if (typeof mostrarAviso === 'function') mostrarAviso('Erro', 'Erro de conexão.');
            }
        }

        function enviarWhatsApp(nome, telefone) {
            if (!telefone) return alert(`Por favor, cadastre o número de ${nome} no botão "Número" primeiro.`);
            const url = obterUrlTerceiro(nome);
            const mes = document.body.dataset.month;
            const ano = document.body.dataset.year;
            const texto = `Olá! O link das suas contas do mês ${mes}/${ano} já está disponível:\n${url}`;
            window.location.href = `whatsapp://send?phone=${telefone}&text=${encodeURIComponent(texto)}`;
        }

        document.addEventListener('DOMContentLoaded', () => {
            const inputEdit = document.getElementById('editTelefoneInput');
            if (inputEdit) {
                inputEdit.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        confirmarSalvarTelefone();
                    }
                });
            }
        });
    </script>
</body>
</html>